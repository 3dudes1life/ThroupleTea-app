</main>
<div aria-hidden="true" class="signup-popup" id="signup-popup">
<div class="signup-overlay" id="signup-overlay"></div>
<div aria-label="A Little Throuple Tea signup form" aria-modal="true" class="signup-box" role="dialog">
<button aria-label="Close signup popup" class="signup-close" id="signup-close" type="button">×</button>
<iframe loading="lazy" src="https://OutAtInc.wixforms.com/f/7470927459844621419" title="A Little Throuple Tea signup form"></iframe>
</div>
</div>
<button class="newsletter-float btn primary" id="newsletter-float" type="button">☕ Join the Tea List</button>
<footer class="site-footer">
<div class="wrap footer-grid">
<p>© <span id="year"></span> A Little Throuple Tea · A 3Dudes1Life Creative project</p>
<p><a href="/episodes/">Episodes</a> · <a href="/watch/">Watch</a> · <a href="/throuple-faq/">FAQ</a></p>
</div>
</footer>
<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  /* Navigation is controlled once by /script.js. */

  const popup = document.getElementById('signup-popup');
  const signupBox = popup ? popup.querySelector('[role="dialog"]') : null;
  let popupReturnFocus = null;
  const getFocusable = () => signupBox ? Array.from(signupBox.querySelectorAll('button, [href], iframe, input, select, textarea, [tabindex]:not([tabindex="-1"])')).filter(el => !el.disabled && el.offsetParent !== null) : [];
  const closePopup = () => {
    if(!popup) return;
    popup.classList.remove('active');
    popup.setAttribute('aria-hidden','true');
    document.body.classList.remove('modal-open');
    if(popupReturnFocus) popupReturnFocus.focus();
  };
  const openPopup = (trigger) => {
    if(!popup) return;
    popupReturnFocus = trigger || document.activeElement;
    popup.classList.add('active');
    popup.setAttribute('aria-hidden','false');
    document.body.classList.add('modal-open');
    const focusable = getFocusable();
    if(focusable.length) focusable[0].focus();
  };
  [document.getElementById('newsletter-trigger'), document.getElementById('newsletter-float')]
    .forEach(el => el && el.addEventListener('click', () => openPopup(el)));
  document.getElementById('signup-close')?.addEventListener('click', closePopup);
  document.getElementById('signup-overlay')?.addEventListener('click', closePopup);
  document.addEventListener('keydown', e => {
    if(!popup || popup.getAttribute('aria-hidden') === 'true') return;
    if(e.key === 'Escape') closePopup();
    if(e.key === 'Tab'){
      const focusable = getFocusable();
      if(!focusable.length) return;
      const first=focusable[0], last=focusable[focusable.length-1];
      if(e.shiftKey && document.activeElement===first){e.preventDefault();last.focus();}
      else if(!e.shiftKey && document.activeElement===last){e.preventDefault();first.focus();}
    }
  });

  /* Original giveaway behavior preserved */
  document.addEventListener("DOMContentLoaded", function(){
    const btn = document.getElementById("push-subscribe-btn");
    const help = document.getElementById("push-help-text");
    if(!btn) return;

    btn.addEventListener("click", function(){
      help.innerHTML = "Checking your browser...";

      const isIos =
        /iPad|iPhone|iPod/.test(navigator.userAgent) ||
        (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1);

      const isStandalone =
        window.navigator.standalone === true ||
        window.matchMedia("(display-mode: standalone)").matches;

      if(isIos && !isStandalone){
        help.innerHTML =
          "iPhone/iPad drama: tap Share → Add to Home Screen, then open Throuple Tea from the app icon and tap this again.";
        return;
      }

      if(!("Notification" in window)){
        help.innerHTML = "This browser does not support web notifications.";
        return;
      }

      window.OneSignalDeferred = window.OneSignalDeferred || [];
      window.OneSignalDeferred.push(async function(OneSignal) {
        try{
          help.innerHTML = "Opening notification prompt...";
          await OneSignal.Notifications.requestPermission();

          if(OneSignal.Notifications.permission){
            help.innerHTML = "✅ You're entered! You'll get weekly signed book giveaway alerts and new episode drops.";
          }else{
            help.innerHTML = "Notifications were not enabled. Check browser settings and try again.";
          }
        }catch(e){
          console.error(e);
          help.innerHTML =
            "Something blocked the notification prompt. Try desktop Chrome, Edge, or the installed Home Screen app.";
        }
      });
    });
  });
</script>
<script src="/script.js"></script>
</body>
</html>
