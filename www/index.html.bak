<style>
    :root{
      --black:#020204;--night:#050812;--deep:#071321;--panel:#091827;
      --hot-pink:#ff005d;--pink:#ff2a7f;--orange:#ff7a18;--sun:#ffb13b;
      --teal:#00d7e8;--white:#fff;--soft:#dff8ff;--muted:#a9dce6;
      --line:rgba(0,215,232,.24);--max:1180px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:92px}
    body{margin:0;background:var(--black);color:var(--soft);font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;line-height:1.65;overflow-x:hidden}
    a{color:inherit}
    img{max-width:100%;height:auto}
    .wrap{width:min(calc(100% - 32px),var(--max));margin:auto}

    .simple-header{
      position:sticky;top:0;z-index:9999;
      background:linear-gradient(90deg,rgba(255,0,93,.12),rgba(0,215,232,.10)),rgba(2,2,4,.94);
      backdrop-filter:blur(18px);
      border-bottom:1px solid rgba(255,42,127,.32);
      box-shadow:0 10px 36px rgba(0,0,0,.35);
    }
    .header-inner{min-height:76px;display:flex;align-items:center;justify-content:space-between;gap:24px}
    .brand img{width:auto;height:52px;border-radius:11px;box-shadow:0 0 20px rgba(255,0,93,.28)}
    .nav-toggle{display:none;min-width:48px;min-height:44px;border:1px solid var(--line);border-radius:10px;background:transparent;color:#fff;font-size:1.25rem}
    .simple-nav{display:flex;align-items:center;gap:20px}
    .simple-nav a{color:#fff;font-weight:800;text-decoration:none;font-size:.91rem}
    .simple-nav a:hover{color:var(--hot-pink)}
    .nav-hotline{
      display:inline-flex;align-items:center;justify-content:center;
      padding:9px 14px;border-radius:999px;
      background:linear-gradient(135deg,var(--hot-pink),var(--orange));
      box-shadow:0 0 18px rgba(255,0,93,.34);
      white-space:nowrap;
    }

    /* Fixed: reduced empty space above the hero content */
    .hero{
      position:relative;overflow:hidden;
      padding:54px 0 66px;
      background:
        radial-gradient(circle at 16% 10%,rgba(255,0,93,.24),transparent 32%),
        radial-gradient(circle at 83% 17%,rgba(0,215,232,.20),transparent 32%),
        linear-gradient(180deg,#020204,#071321 56%,#020204);
    }
    .hero-grid{display:grid;grid-template-columns:minmax(0,1.08fr) minmax(330px,.62fr);gap:52px;align-items:center}
    .eyebrow{display:flex;align-items:center;gap:10px;color:var(--sun);font-weight:900;text-transform:uppercase;letter-spacing:.14em;font-size:.75rem}
    .eyebrow:before{content:"";width:34px;height:1px;background:var(--hot-pink)}
    h1,h2,h3{line-height:1.08}
    h1{margin:13px 0 18px;color:#fff;font-size:clamp(2.8rem,4.45vw,4.85rem);letter-spacing:-.052em;text-align:center}
    h1 .hero-line{display:block;white-space:nowrap}
    h1 .hero-line.accent{color:var(--hot-pink);text-shadow:0 0 24px rgba(255,0,93,.42)}
    .hero-sub{max-width:760px;margin:0 auto;color:#dff8ff;font-size:clamp(1.05rem,1.4vw,1.22rem);text-align:center}
    .proof-row{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin:22px 0}
    .proof-row span{padding:9px 12px;border:1px solid rgba(255,255,255,.14);border-radius:999px;color:#fff;background:rgba(255,255,255,.045);font-weight:800;font-size:.84rem}
    .cta-row{display:flex;flex-wrap:wrap;justify-content:center;gap:11px;margin-top:25px}
    .btn{display:inline-flex;align-items:center;justify-content:center;min-height:50px;padding:13px 20px;border:1px solid rgba(0,215,232,.48);border-radius:999px;color:#fff;text-decoration:none;font-weight:900;background:rgba(255,255,255,.035);cursor:pointer}
    .btn.primary{border:0;background:linear-gradient(135deg,var(--hot-pink),var(--orange));box-shadow:0 9px 28px rgba(255,0,93,.35)}
    .btn:hover{transform:translateY(-2px)}

    /* Fixed: real RSS artwork URL, contained instead of cropped */
    .hero-art{
      position:relative;padding:14px;border-radius:28px;
      border:1px solid rgba(0,215,232,.25);
      background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.025));
      box-shadow:0 30px 90px rgba(0,0,0,.55);
    }
    .hero-art img{display:block;width:100%;aspect-ratio:1/1;border-radius:20px;object-fit:contain;background:#020204}
    .rank-badge{position:absolute;left:-18px;bottom:26px;max-width:260px;padding:14px 16px;border-radius:16px;background:#fff;color:#111;font-weight:900;box-shadow:0 18px 50px rgba(0,0,0,.48)}

    .section{padding:76px 0;border-top:1px solid rgba(255,255,255,.075)}
    .section-title{max-width:820px;margin:0 0 18px;color:#fff;font-size:clamp(2.3rem,4.6vw,4.8rem);letter-spacing:-.045em}
    .section-lede{max-width:800px;margin:0 0 38px;color:var(--muted);font-size:1.12rem}
    .platforms{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
    .platform-card{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:150px;padding:18px;border:1px solid var(--line);border-radius:20px;background:linear-gradient(180deg,rgba(255,255,255,.07),rgba(255,255,255,.025));text-decoration:none;text-align:center;font-weight:900}
    .platform-card img{width:46px;height:46px;object-fit:contain;margin-bottom:10px}
    .latest-grid,.search-cluster{display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:center}
    .video-shell{overflow:hidden;border:1px solid rgba(255,42,127,.35);border-radius:24px;box-shadow:0 22px 70px rgba(0,0,0,.5)}
    .video-shell iframe{display:block;width:100%;aspect-ratio:16/9;border:0}
    .feature-grid,.hosts-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .feature-card,.host-card,.seo-copy{padding:26px;border:1px solid var(--line);border-radius:22px;background:rgba(255,255,255,.042)}
    .feature-card small{color:var(--sun);font-weight:900;text-transform:uppercase;letter-spacing:.1em}
    .feature-card h3,.host-card h3{margin:16px 0 10px;color:var(--hot-pink);font-size:1.45rem}
    .feature-card p,.host-card p,.seo-copy p{margin:0;color:var(--muted)}
    .quick-links{display:grid;gap:12px}
    .quick-links a{display:flex;justify-content:space-between;padding:18px;border:1px solid var(--line);border-radius:16px;text-decoration:none;font-weight:900;background:rgba(255,255,255,.035)}
    .giveaway{padding:34px;border:1px solid rgba(255,42,127,.4);border-radius:25px;background:linear-gradient(135deg,rgba(255,0,93,.13),rgba(255,122,24,.10));text-align:center}
    .giveaway h2{margin-top:0;color:#fff}
    .tiny-note{margin-top:1rem;color:var(--muted);font-size:.92rem}
    .site-footer{padding:34px 0 calc(44px + env(safe-area-inset-bottom));border-top:1px solid rgba(255,42,127,.28);background:#020204}
    .footer-grid{display:flex;justify-content:space-between;gap:24px;color:#b9e5eb;font-size:.9rem}
    .newsletter-float{position:fixed;right:15px;bottom:15px;z-index:9998}
    .signup-popup{display:none;position:fixed;inset:0;z-index:100000}.signup-popup.active{display:block}
    .signup-overlay{position:absolute;inset:0;background:rgba(0,0,0,.78);backdrop-filter:blur(5px)}
    .signup-box{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:min(94vw,560px);max-height:90vh;overflow:auto;padding:14px;border:2px solid rgba(255,42,127,.45);border-radius:24px;background:#050812}
    .signup-box iframe{width:100%;height:620px;border:0;border-radius:16px;background:#fff}
    .signup-close{position:absolute;right:20px;top:20px;z-index:2;width:38px;height:38px;border:0;border-radius:50%;background:linear-gradient(135deg,var(--hot-pink),var(--orange));color:#fff;font-size:1.5rem}

    @media(max-width:980px){
      .nav-toggle{display:inline-flex;align-items:center;justify-content:center}
      .simple-nav{display:none;position:absolute;left:0;right:0;top:76px;padding:20px;background:#050812;border-bottom:1px solid var(--line);flex-direction:column;align-items:stretch}
      .simple-nav.open{display:flex}
      .simple-nav a{padding:12px 0;border-bottom:1px solid rgba(255,255,255,.08)}
      .nav-hotline{width:100%}
      .hero{padding:42px 0 58px}
      .hero-grid,.latest-grid,.search-cluster{grid-template-columns:1fr}
      .hero-art{width:min(100%,520px);margin:auto}
      .rank-badge{left:14px;bottom:18px}
      .platforms{grid-template-columns:repeat(3,1fr)}
    }
    @media(max-width:680px){
      .wrap{width:min(calc(100% - 26px),var(--max))}
      .header-inner{min-height:68px;padding-top:env(safe-area-inset-top)}
      .brand img{height:44px}.simple-nav{top:68px}
      .hero{padding:32px 0 48px}
      h1{font-size:clamp(1.65rem,8.1vw,3.25rem);letter-spacing:-.045em}
      .hero-grid{gap:30px}
      .hero-sub{font-size:1.02rem;line-height:1.62}
      .proof-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:9px;margin:20px 0}
      .proof-row span{display:flex;align-items:center;justify-content:center;min-height:58px;padding:9px 8px;border-radius:17px;font-size:.78rem;line-height:1.22;text-align:center}
      .cta-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-top:22px}
      .cta-row .btn{width:100%;min-height:58px;padding:12px 10px;border-radius:18px;font-size:.92rem;line-height:1.15;text-align:center}
      .cta-row .btn.primary{grid-column:1/-1;min-height:62px;font-size:1.05rem}
      .newsletter-float{left:auto;right:12px;bottom:calc(12px + env(safe-area-inset-bottom));width:auto!important;min-height:46px;padding:10px 15px;border-radius:999px;font-size:.82rem;box-shadow:0 10px 30px rgba(0,0,0,.45),0 0 22px rgba(255,0,93,.3)}
      .hero-art{padding:10px;border-radius:21px}
      .hero-art img{border-radius:15px}
      .rank-badge{position:static;max-width:none;margin-top:12px;text-align:center}
      .section{padding:60px 0}
      .platforms{grid-template-columns:repeat(2,1fr)}
      .feature-grid,.hosts-grid{grid-template-columns:1fr}
      .footer-grid{flex-direction:column}
      .signup-box iframe{height:560px}
    }
  </style>
<meta content="dark" name="color-scheme"/></head>
